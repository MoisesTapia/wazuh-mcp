# ── Wazuh API REST ────────────────────────────────────────────────────────────
# Host del Manager. 'localhost' si Wazuh corre en Docker en tu máquina.
WAZUH_HOST=localhost

# Puerto de la API REST (default 55000)
WAZUH_PORT=55000

# Usuario y contraseña de la API REST de Wazuh.
# Usa un usuario de mínimo privilegio dedicado al MCP, no el admin del Dashboard.
WAZUH_USER=<wazuh-api-user>
WAZUH_PASSWORD=<strong-password-here>

# ── TLS / SSL ─────────────────────────────────────────────────────────────────
# Verificación de certificado TLS del Manager.
# - Desarrollo local con cert auto-firmado: false (solo con WAZUH_HOST=localhost)
# - Producción: true (usa el CA bundle del sistema)
# - Producción con CA personalizada: usa WAZUH_CA_BUNDLE en su lugar
WAZUH_VERIFY_SSL=true

# Ruta al CA bundle PEM del Manager para producción con CA interna.
# Cuando está definido, WAZUH_VERIFY_SSL se ignora (SSL SIEMPRE verificado).
# En producción usa: WAZUH_CA_BUNDLE=/var/ossec/etc/sslmanager.cert
# WAZUH_CA_BUNDLE=

# ── Token JWT ─────────────────────────────────────────────────────────────────
JWT_REFRESH_MARGIN=60

# ── HTTP Client ───────────────────────────────────────────────────────────────
REQUEST_TIMEOUT=30
MAX_RETRIES=3

# ── Contraseña del Indexer (OpenSearch) ───────────────────────────────────────
# Debe coincidir con el hash en config/wazuh_indexer/internal_users.yml
# Para desarrollo, no cambies esto a menos que también actualices el hash.
INDEXER_PASSWORD=<indexer-password-here>

# ── Wazuh Indexer — Tools SOC (alertas y CVEs) ────────────────────────────────
# Wazuh 4.8.0+ almacena alertas y vulnerabilidades en el Indexer (puerto 9200).
# Sin esta configuración las tools get_alerts, get_vulnerabilities, etc. devuelven
# un error claro en lugar de fallar.
#
# WAZUH_INDEXER_HOST=localhost
# WAZUH_INDEXER_PORT=9200
# WAZUH_INDEXER_USER=admin
# WAZUH_INDEXER_PASSWORD=SecretPassword
# WAZUH_INDEXER_VERIFY_SSL=false

# ── MCP Transport ─────────────────────────────────────────────────────────────
# Modo stdio (Claude Desktop): no se necesita configuración adicional.
# MCP_TRANSPORT=stdio

# Modo HTTP (Docker / red local):
#   RIESGO: El servidor HTTP expone todos los tools de Wazuh sobre la red.
#   - MCP_HOST debe ser 127.0.0.1 (loopback) a menos que uses un proxy con TLS.
#   - MCP_API_KEY es OBLIGATORIA en modo HTTP. El servidor rechazará el arranque sin ella.
#   - Genera una clave segura con: openssl rand -hex 32
#
# MCP_TRANSPORT=http
# MCP_HOST=127.0.0.1
# MCP_PORT=8000
# MCP_API_KEY=<genera-con-openssl-rand-hex-32>

# ── Auditoría / Logging ───────────────────────────────────────────────────────
# Nivel de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Ruta al archivo de log rotante (además de stderr). Omitir para solo stderr.
# LOG_FILE=/var/log/wazuh-mcp/audit.log

# Deshabilitar auditoría: poner a false solo en entornos de prueba aislados.
AUDIT_ENABLED=true
